# Java poker examples - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI container jobs

set shell := ["bash", "-c"]

ROOT := `git rev-parse --show-toplevel`

default:
    @just --list

# Export protos from buf.build into the client library's proto source tree so
# protobuf-gradle-plugin compiles them alongside the core angzarr protos.
# Excludes ai_sidecar.proto (enum conflicts with poker_types.proto).
proto-gen:
    buf export buf.build/angzarr/angzarr -o "{{ROOT}}/angzarr-client-java/angzarr/proto"
    buf export buf.build/angzarr/examples -o "{{ROOT}}/angzarr-client-java/angzarr/proto" --exclude-path examples/ai_sidecar.proto

build: proto-gen
    ./gradlew build -x test

build-dev: proto-gen
    ./gradlew build -x test --info

test-unit: proto-gen
    ./gradlew test --tests "*Test"

test-acceptance: proto-gen
    ./gradlew :tests:test

test: proto-gen
    ./gradlew test

fmt:
    ./gradlew spotlessApply || echo "Spotless not configured, skipping format"

lint: proto-gen
    ./gradlew check -x test

deps:
    ./gradlew dependencies --configuration compileClasspath

wrapper-update:
    ./gradlew wrapper --gradle-version latest
